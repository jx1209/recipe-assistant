# recipe assistant backend configuration

# environment (development, staging, production, testing)
ENVIRONMENT=development
DEBUG=true

# server configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# database
DATABASE_URL=data/recipe_assistant.db

# security - important: change these in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET_KEY=your-super-secret-session-key-change-this-in-production
ENCRYPTION_KEY=your-super-secret-encryption-key-change-this-in-production

# cors - frontend urls allowed to access the api
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ai integration (optional)
AI_ENABLED=false
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# logging
LOG_LEVEL=INFO
LOG_FILE=logs/recipe_assistant.log

# features (enable/disable)
FEATURE_AI_GENERATION=false
FEATURE_MEAL_PLANNING=true
FEATURE_SHOPPING_LISTS=true
FEATURE_NUTRITION_TRACKING=true
FEATURE_RECOMMENDATIONS=true
FEATURE_SOCIAL_SHARING=false

# rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# file upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=data/uploads

# external apis (optional)
USDA_API_KEY=your-usda-api-key
NUTRITION_API_ENABLED=false

# email (optional - for password reset, etc.)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@recipeassistant.com

# caching (optional)
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379

# frontend url
FRONTEND_URL=http://localhost:3000
